  "macron": {
    "name": "Emmanuel Macron",
    "role": "Président de la République",
    "party": "Renaissance",
    "bio": "Former Rothschild banker who won the presidency at 39, Macron made possibly the worst political gamble in modern French history when he dissolved the National Assembly in June 2024 after RN crushed his party in European elections—resulting in a hung parliament and unprecedented chaos with THREE prime ministers (Barnier, Bayrou, Lecornu) in under a year, two toppled by censure motions. He admitted in his New Year's address that the dissolution 'brought more division than solutions,' a rare concession from Jupiter himself. His second term has been defined by the forced-through pension reform (massive protests in 2023), losing his parliamentary majority, and becoming increasingly isolated as a lame duck president who can't dissolve again until 2025. Now presiding over France's worst political crisis since the Fifth Republic began, with approval ratings in the basement and every ambitious politician from Philippe to Bardella already running for 2027 to replace him.",
    "meme_summary": "The perfect target for 'out-of-touch elite' mockery with his condescending tone, Jupiterian self-image, and endless supply of cringe-worthy quotes.",
    "archetype": "The out-of-touch elite / Jupiterian President",
    "best_takedown_angle": "Mock his corporate background and banker attitude—portray him as a rich guy who thinks he knows better than ordinary people. Emphasize his dismissive tone toward critics.",
    "visual_gags": [
      "Expensive watch peeking from sleeve",
      "Walking away from protests like a boss",
      "Awkward forced smile",
      "Pointing dramatically",
      "The 'Pharaoh' pose",
      "Looking down his nose at plebs"
    ],
    "catchphrases": [
      "En même temps",
      "Je ne céderai rien",
      "Make our planet great again",
      "Start-up nation",
      "Les Gaulois sont réfractaires au changement",
      "La meilleure façon de se payer un costard c'est de travailler"
    ],
    "combo_partners": "Mélenchon (two delusional egos clashing), Le Pen (elitist vs populist showdown), Valls (the two comeback kids nobody wanted)",
    "target_audience": "Right-wing anti-globalists, yellow vests, working class, nationalist youth",
    "traits": [
